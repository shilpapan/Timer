# API Configuration
# Copy this file to .env and update with your actual API endpoint

# Base URL for the Visit Tracker API
VITE_API_BASE_URL=http://localhost:3000/api

# Optional: API Key if your backend requires authentication
# VITE_API_KEY=your_api_key_here

# Optional: Refresh interval in milliseconds (default: 30000)
# VITE_REFRESH_INTERVAL=30000